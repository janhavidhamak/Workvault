# Supabase — Project Settings → General (reference) and → API (URL + anon key).
# VITE_* vars are exposed to the browser; use RLS. Never put the service_role key here.
VITE_SUPABASE_PROJECT_REF="your-project-ref"
# Optional override; if unset, the app builds https://<VITE_SUPABASE_PROJECT_REF>.supabase.co
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
